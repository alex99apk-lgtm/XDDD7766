local a = getgenv()
local b = a.request or a.http_request or (a.syn and a.syn.request)
local c = a.loadstring or loadstring

-- GUARDAMOS LAS FUNCIONES ORIGINALES AQUÍ:
a.OriginalRequest = b
a.OriginalLoadstring = c

if restorefunction then
    pcall(restorefunction, c)
    if b then pcall(restorefunction, b) end
end

local d = a.loadstring or loadstring
local e = clonefunction(d)

local f = newcclosure(function(g, h)
    return e(g, h)
end)

local i = newcclosure(function(j)
    if type(j) == "table" and j.Url and string.match(string.lower(j.Url), "discord") then
        return {StatusCode = 404, Body = "Blocked", Headers = {}}
    end
    if b then return b(j) end
end)

if hookfunction then
    pcall(hookfunction, c, f)
    pcall(hookfunction, loadstring, f)
    if b then pcall(hookfunction, b, i) end
end

a.loadstring = f
loadstring = f

if b then
    a.request = i
    a.http_request = i
    if a.syn then a.syn.request = i end
end

local uiName = "LoaderAnti"
local targetParent = pcall(function() return game:GetService("CoreGui") end) and game:GetService("CoreGui") or game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

if targetParent:FindFirstChild(uiName) then
    targetParent[uiName]:Destroy()
end

local hiddenGui = Instance.new("ScreenGui")
hiddenGui.Name = uiName
hiddenGui.Enabled = false 
hiddenGui.ResetOnSpawn = false
hiddenGui.IgnoreGuiInset = true
hiddenGui.Parent = targetParent

-- TAREA PROGRAMADA: Espera 3.5 segundos, elimina la UI y restaura el entorno
task.spawn(function()
    task.wait(4.5)
    
    -- 1. Restaurar las funciones C originales desde el respaldo
    if restorefunction then
        if a.OriginalLoadstring then 
            pcall(restorefunction, a.OriginalLoadstring) 
        end
        if a.OriginalRequest then 
            pcall(restorefunction, a.OriginalRequest) 
        end
    end

    -- 2. Devolver las variables globales a su estado natural
    if a.OriginalLoadstring then
        a.loadstring = a.OriginalLoadstring
        loadstring = a.OriginalLoadstring
    end

    if a.OriginalRequest then
        a.request = a.OriginalRequest
        a.http_request = a.OriginalRequest
        if a.syn then 
            a.syn.request = a.OriginalRequest 
        end
    end

    -- 3. Limpiar la UI oculta de forma segura
    if hiddenGui and hiddenGui.Parent then
        hiddenGui:Destroy()
    end
    
    -- Limpieza adicional por si acaso quedó algún rastro en el parent
    if targetParent and targetParent:FindFirstChild(uiName) then
        targetParent[uiName]:Destroy()
    end
end)
